# ─────────────────────────────────────────────────────────────
# FRONTEND (build-time — CRA embeds REACT_APP_* into the bundle)
# On Vercel: Project → Settings → Environment Variables, then redeploy.
# ─────────────────────────────────────────────────────────────

# Base URL of the deployed backend (server.js). No trailing slash.
# Example: https://baiterek-api.up.railway.app
# If unset, the app falls back to http://localhost:3001 (local dev).
REACT_APP_API_BASE=

# AI assistant (OpenRouter).
# WARNING: any REACT_APP_* value is visible in the public JS bundle.
# Prefer proxying AI calls through server.js instead of exposing this key.
REACT_APP_OPENROUTER_KEY=

# ─────────────────────────────────────────────────────────────
# BACKEND (server.js)
# ─────────────────────────────────────────────────────────────

# Secret for signing JWT tokens — use a long random value in production.
JWT_SECRET=change_me_to_a_long_random_string

# PORT is provided automatically by the hosting platform (Railway/Render/Fly).
# Locally the server defaults to 3001.
